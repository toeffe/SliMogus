{
  "name": "slimogus",
  "private": true,
  "version": "0.1.0",
  "description": "Browser-based, peer-to-peer social deduction party game built with Vite, TypeScript, and Three.js.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "assets:textures": "node scripts/bakeTexturelabs.mjs",
    "assets:skybox": "node scripts/bakeSpaceSkybox.mjs",
    "assets:icons": "node scripts/generateAssets.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "lz-string": "^1.5.0",
    "peerjs": "^1.5.5",
    "seedrandom": "^3.0.5",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.185.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ],
    "*.{ts,js,json,css,md,html}": [
      "prettier --write"
    ]
  }
}
